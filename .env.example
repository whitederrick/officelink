# OFFICELINK environment example
# Copy this to .env.local for local development. Do not commit real secrets.

# File-based JSON storage directory.
# Local default: ./.data
# Vercel/production default: os.tmpdir()/officelink-data
# Note: Vercel tmp storage is ephemeral and can be reset between function runs.
# OFFICELINK_DATA_DIR=./.data

# Optional base URL when native clients or external frontends call the API.
# Leave empty for same-origin web/PWA usage.
# NEXT_PUBLIC_API_BASE_URL=https://api.officelink.example.com

# Future real database target.
# DATABASE_URL=postgres://officelink:officelink@localhost:5432/officelink
